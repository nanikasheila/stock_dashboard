{
  "$schema": "./settings.schema.json",
  "github": {
    "owner": "nanikasheila",
    "repo": "stock_dashboard",
    "mergeMethod": "merge"
  },
  "issueTracker": {
    "provider": "none"
  },
  "branch": {
    "user": "nanikasheila",
    "format": "<user>/<type>-<description>"
  },
  "project": {
    "name": "stock_dashboard",
    "language": "python",
    "entryPoint": "run.py",
    "test": {
      "command": "python -m pytest tests/ -q",
      "directory": "tests/",
      "pattern": "test_*.py"
    }
  },
  "agents": {
    "model": "Claude Sonnet 4.6 (copilot)",
    "architect": {
      "model": "Claude Opus 4.6 (copilot)"
    },
    "assessor": {
      "model": "Claude Opus 4.6 (copilot)"
    },
    "manager": {
      "model": "Claude Opus 4.6 (copilot)"
    }
  }
}
