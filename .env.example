# Optional Neo4j graph storage
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=<your-neo4j-password>
NEO4J_MODE=off

# Optional TEI (Text Embeddings Inference) endpoint
TEI_URL=http://localhost:8081

# Optional cache tuning
YFINANCE_CACHE_TTL_HOURS=1

# Leave empty to use the default data/cache directory under the repo root
STOCK_DASHBOARD_CACHE_DIR=
